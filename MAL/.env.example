# Kopier denne fil til .env og udfyld med rigtige værdier.
# .env er gitignored - committ aldrig rigtige secrets.

# Postgres database password (brug en stærk tilfældig værdi)
DB_PASSWORD=skift_mig_til_staerkt_password

# API nøgle der bruges til at authenticere kald til C# serveren.
# Skal sendes som X-API-Key header på alle /api/* HTTP requests.
# Skal sendes som "AUTH:<nøgle>;" som første besked på socket forbindelser.
API_KEY=skift_mig_til_tilfaeldig_streng

WEB_USERNAME=brugernavn
WEB_PASSWORD=adgangskode