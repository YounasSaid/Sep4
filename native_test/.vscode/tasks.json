{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "1: Build all native tests (release)",
            "command": "make",
            "type": "shell",
            "args": [
                "native_tests"
            ],
            "problemMatcher": [
                "$gcc"
            ],
            "presentation": {
                "reveal": "always",
                "clear": true
            },
            "group": {
                "kind": "build"
            }
        },
        {
            "label": "2: Build all native tests (debug)",
            "command": "make",
            "type": "shell",
            "args": [
                "native_tests",
                "CONFIG=DEBUG"
            ],
            "problemMatcher": [
                "$gcc"
            ],
            "presentation": {
                "reveal": "always",
                "clear": true
            },
            "group": {
                "kind": "build"
            }
        },
        {
            "label": "3: Run all native tests (release)",
            "dependsOn": [
                "1: Build all native tests (release)"
            ],
            "command": "make",
            "type": "shell",
            "args": [
                "run_all_tests"
            ],
            "problemMatcher": {
                "owner": "batch",
                "fileLocation" : [
                    "absolute"
                ],
                "pattern" :[
                    {
                        "regexp": "^(.*):(\\d+):(.*):FAIL:(.*)$",
                        "file": 1,
                        "line": 2,
                        "message": 4
                    }
                ]
            },
            "presentation": {
                "reveal": "always",
                "revealProblems": "onProblem",
                "clear": true,
                "panel": "dedicated"
            },
            "group": {
                "kind": "test",
                "isDefault": true
            }
        },
        {
            "label": "4: Run all native tests (debug)",
            "dependsOn": [
                "2: Build all native tests (debug)"
            ],
            "command": "make",
            "type": "shell",
            "args": [
                "run_all_tests",
                "CONFIG=DEBUG"
            ],
            "problemMatcher": {
                "owner": "batch",
                "fileLocation" : [
                    "absolute"
                ],
                "pattern" :[
                    {
                        "regexp": "^(.*):(\\d+):(.*):FAIL:(.*)$",
                        "file": 1,
                        "line": 2,
                        "message": 4
                    }
                ]
            },
            "presentation": {
                "reveal": "always",
                "revealProblems": "onProblem",
                "clear": true,
                "panel": "dedicated"
            },
            "group": {
                "kind": "test",
                "isDefault": false
            }
        },
        {
            "label": "5: Clean native tests",
            "command": "make",
            "type": "shell",
            "args": [
                "clean"
            ],
            "problemMatcher": [],
            "presentation": {
                "reveal": "always",
                "clear": true
            },
            "group": {
                "kind": "build"
            }
        }
    ]
}